APP_NAME="CIHRMS MVP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────
# Local development defaults to SQLite for zero-setup onboarding. Production
# MUST use PostgreSQL — SQLite's per-write locking is not fit for concurrent
# writers, and the IPPD / GIFMIS / Auditor-General export jobs depend on
# COPY-style streaming we only get on Postgres.
#
# To switch to Postgres for production or staging:
#   1. Set DB_CONNECTION=pgsql + the host/port/database/user/password lines below
#   2. Run: php artisan migrate --force
#   3. See docs/ops/postgres-migration.md for the full migration runbook.
DB_CONNECTION=sqlite

# Postgres (production):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=cihrms
# DB_USERNAME=cihrms
# DB_PASSWORD=

# MySQL / MariaDB (alternative — community deployments):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Production: set SESSION_ENCRYPT=true so the sessions table cannot be
# read in plaintext if the DB is compromised. (Cost: ~0.1ms per request.)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: set SESSION_SECURE_COOKIE=true (requires HTTPS).
# Cookie http_only=true and same_site=lax are already enforced in config/session.php.
SESSION_SECURE_COOKIE=false

# Production: set to "*" if running behind a trusted load balancer / reverse proxy.
APP_TRUSTED_PROXIES=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Production hardening (P6) ──
# Sentry — set SENTRY_LARAVEL_DSN to enable error reporting via the 'sentry' log channel
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# Default log channel in production (override LOG_CHANNEL above for prod env files)
LOG_CHANNEL_PRODUCTION=stack

# spatie/laravel-backup destination
BACKUP_ARCHIVE_PASSWORD=
BACKUP_FILESYSTEM_DISK=local

# ──────────────────────────────────────────────────────────────────────
# F4 — Paystack Gateway (member fees + AR receipts)
# Webhook: register https://<APP_URL>/webhooks/paystack on the Paystack
# dashboard with the same secret. Without it, payments charge but never
# reconcile to AR invoices.
# ──────────────────────────────────────────────────────────────────────
PAYSTACK_URL=https://api.paystack.co
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_RECEIPT_BANK_PURPOSE=receipts
PAYSTACK_CALLBACK_DEFAULT_URL=

# ──────────────────────────────────────────────────────────────────────
# Website finance integration — nightly pull of verified member/collection
# records from cihrm_website (GET {WEBSITE_SYNC_URL}/api/finance-sync/*,
# bearer-authed with WEBSITE_SYNC_TOKEN). Runs via `sync:website-collections`
# (scheduled daily at 01:30). Leave blank in non-production — the command
# will error against an empty URL rather than silently no-op.
# ──────────────────────────────────────────────────────────────────────
WEBSITE_SYNC_URL=
WEBSITE_SYNC_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# SMS — Hubtel (Ghana-native, default) / Twilio (international fallback)
# Set SMS_DRIVER=hubtel|twilio|log. `log` writes SMS to storage/logs and
# is the safe dev default. Production MUST set hubtel|twilio + creds, or
# every outbound SMS row ends up Failed.
# Hubtel webhook URLs to register on the Hubtel dashboard:
#   - Delivery receipts:  https://<APP_URL>/webhooks/sms
#   - USSD:               https://<APP_URL>/webhooks/ussd
# ──────────────────────────────────────────────────────────────────────
SMS_DRIVER=log
SMS_LOG_CHANNEL=stack

HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=CIHRMS
HUBTEL_BASE_URL=https://smsc.hubtel.com
HUBTEL_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ──────────────────────────────────────────────────────────────────────
# USSD — short code registered with your network operator
# ──────────────────────────────────────────────────────────────────────
USSD_SHORTCODE=*920*HR#
USSD_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Identity verification — NIA (Ghana Card) + generic KYC vendor
# Default IDENTITY_PROVIDER=mock works without creds (dev only).
# Production MUST set IDENTITY_PROVIDER=nia + creds.
# ──────────────────────────────────────────────────────────────────────
IDENTITY_PROVIDER=mock
IDENTITY_VALIDITY_MONTHS=12

NIA_BASE_URL=
NIA_API_KEY=
NIA_TIMEOUT=30

KYC_VENDOR=
KYC_BASE_URL=
KYC_API_KEY=
KYC_TIMEOUT=30

# ──────────────────────────────────────────────────────────────────────
# Statutory payroll — GHIPSS disbursement + IPPD + GIFMIS GL mapping
# All optional in non-production. GHIPSS/IPPD outputs land on the disk
# below; GIFMIS auto-mints journal entries on payroll approval if
# GIFMIS_AUTO_MINT=true.
# ──────────────────────────────────────────────────────────────────────
GHIPSS_ENABLED=false
GHIPSS_ORIGINATOR_NAME=CIHRMS
GHIPSS_SPONSOR_SORT_CODE=
GHIPSS_OUTPUT_DISK=local

IPPD_MDA_CODE=
IPPD_OUTPUT_DISK=local

GIFMIS_AUTO_MINT=false
GIFMIS_OUTPUT_DISK=local
GIFMIS_COST_CENTRE=
GIFMIS_GL_DR_SALARY=
GIFMIS_GL_DR_SSNIT_EMP=
GIFMIS_GL_DR_TIER2_EMP=
GIFMIS_GL_CR_NET=
GIFMIS_GL_CR_PAYE=
GIFMIS_GL_CR_SSNIT_EE=
GIFMIS_GL_CR_SSNIT_EMP=
GIFMIS_GL_CR_TIER2=
GIFMIS_GL_CR_TIER3=
GIFMIS_GL_CR_NHIA=
GIFMIS_GL_CR_VOLUNTARY=

E_LEVY_RATE_FALLBACK=0.015

# ──────────────────────────────────────────────────────────────────────
# Mobile-money providers (optional alternative to Paystack)
# ──────────────────────────────────────────────────────────────────────
MOMO_MTN_ENABLED=false
MOMO_MTN_ENVIRONMENT=sandbox
MOMO_MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_MTN_SUBSCRIPTION_KEY=
MOMO_MTN_API_USER=
MOMO_MTN_API_KEY=

MOMO_VF_ENABLED=false
MOMO_VF_BASE_URL=
MOMO_VF_API_KEY=
MOMO_VF_SIGNING_SECRET=

MOMO_AT_ENABLED=false
MOMO_AT_BASE_URL=
MOMO_AT_CLIENT_ID=
MOMO_AT_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Integrations — Slack / Microsoft Teams / WhatsApp / Google / Microsoft
# Used by MessagingDispatcher for leave/incident notifications, and by
# the calendar / file / CRM integrations. Per-channel feature flags
# below toggle the user-facing wiring.
# ──────────────────────────────────────────────────────────────────────
INT_MSG_DRIVER=mock
INT_CAL_DRIVER=mock
INT_FILES_DRIVER=mock
INT_SHEETS_DRIVER=mock
INT_CRM_DRIVER=mock
INT_IDP_DRIVER=mock
INT_ESIGN_DRIVER=mock

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_HR_CHANNEL=
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="CIHRMS Log"
LOG_SLACK_EMOJI=":boom:"

TEAMS_HR_WEBHOOK=

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CHANNEL_TOKEN=

MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_GRAPH_CLIENT_STATE=

# ──────────────────────────────────────────────────────────────────────
# eSign providers — Zoho Sign / DocuSign
# Webhooks: /webhooks/esign with the matching secret below.
# ──────────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REGION=com
ZOHO_WEBHOOK_SECRET=

ZOHO_SIGN_CLIENT_ID=
ZOHO_SIGN_CLIENT_SECRET=
ZOHO_SIGN_WEBHOOK_SECRET=

DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_CONNECT_KEY=

# ──────────────────────────────────────────────────────────────────────
# AI agent runtime (optional — AI assistant features)
# ──────────────────────────────────────────────────────────────────────
AI_ENABLED=false
AI_DRIVER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=60

# ──────────────────────────────────────────────────────────────────────
# Feature flags — turn on/off cross-cutting integrations
# ──────────────────────────────────────────────────────────────────────
FLAG_AUTO_SYNC_CRM=false
FLAG_DOC_MIRROR=false
FLAG_SLACK_LEAVE=false
FLAG_TEAMS_TICKETS=false
FLAG_WA_PAYSLIP=false

# ──────────────────────────────────────────────────────────────────────
# Mail — alternative providers (uncomment + set MAIL_MAILER above)
# ──────────────────────────────────────────────────────────────────────
# POSTMARK_API_KEY=
# POSTMARK_MESSAGE_STREAM_ID=
# RESEND_API_KEY=
# MAIL_EHLO_DOMAIN=
# MAIL_LOG_CHANNEL=stack

# ──────────────────────────────────────────────────────────────────────
# Backups — destination email + scheduling
# ──────────────────────────────────────────────────────────────────────
BACKUP_NOTIFY_EMAIL=
